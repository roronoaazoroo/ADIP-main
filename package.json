{
  "name": "azure-drift-intelligence-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm run install:all && npm run env:sync",
    "install:all": "npm install && npm install --prefix adip-backend/express-api && npm install --prefix adip-backend/function-app",
    "env:sync": "node scripts/sync-env.cjs",
    "dev": "vite",
    "dev:api": "npm start --prefix adip-backend/express-api",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:func": "npm run deploy --prefix adip-backend/function-app"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "deep-diff": "^1.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0"
  }
}
